# Database
DATABASE_URL=postgresql+asyncpg://compliance:compliance@localhost:5432/compliance
DATABASE_URL_SYNC=postgresql://compliance:compliance@localhost:5432/compliance

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Provider (OpenAI-compatible)
AI_API_KEY=
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=

# Crawler
CRAWLER_RATE_LIMIT=2
CRAWLER_TIMEOUT=30
CRAWLER_ALLOWED_DOMAINS=bb.org.bd,bfiu.org.bd

# App
APP_NAME=BD Compliance
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
